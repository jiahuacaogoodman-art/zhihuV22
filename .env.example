# ============================================================
# 智护银伴 · 本地环境变量示例
# 复制为 .env 并按实际情况修改，.env 已被 .gitignore 排除，不会提交到仓库。
# ============================================================

# --- 鉴权 ---
# 所有 /api/* 和 /uploads/* 请求必须携带请求头：X-Auth-Token: <AUTH_TOKEN>
# 留空则鉴权关闭（仅限开发/测试环境）。
# 生产环境请使用 openssl rand -hex 32 生成随机 token。
AUTH_TOKEN=

# --- 服务监听 ---
HOST=0.0.0.0
PORT=8000

# --- 开发模式热重载（生产禁止开启）---
RELOAD=0

# --- 病历上传限制 ---
MAX_UPLOAD_SIZE_MB=15
