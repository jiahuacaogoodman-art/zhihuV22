# ============================================================
# 智护银伴 · 环境变量配置
# 复制为 .env 并按实际情况修改。.env 已被 .gitignore 排除，不会提交到仓库。
#
# 💡 推荐：直接运行一键部署向导，自动填写所有配置：
#      chmod +x scripts/setup.sh && ./scripts/setup.sh
# ============================================================

# ─────────────────────────────────────────────────────────────
# 1. 安全密钥（必填，生产环境必须设置）
# ─────────────────────────────────────────────────────────────

# 管理员 Token（Bootstrap Token）
# 首次启动时自动创建 admin 用户，此 Token 成为其 API Key。
# 之后即使删除本变量，admin 的 token 也已入库继续有效。
# 留空 + UserStore 为空 → 鉴权关闭（仅限开发/测试）。
# 生成：openssl rand -hex 32
AUTH_TOKEN=

# PII 字段加密密钥（Fernet, 44 字符 URL-safe base64）
# 启用后姓名/身份证/联系方式等 10 个敏感字段写入前自动加密。
# 留空 → 加密关闭（仅限开发/测试）。
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
# 2. LLM 推理后端（二选一）
# ─────────────────────────────────────────────────────────────

# Provider 选择：ollama（默认）或 openai（任何 OpenAI 兼容端点）
# 一键部署向导 (setup.sh) 会自动帮你选择和填写。
LLM_PROVIDER=ollama

# ── 2A. Ollama 配置（LLM_PROVIDER=ollama 时生效）──
# Docker Compose 默认从 HuggingFace 自动拉取，量化档位选择：
#   hf.co/mradermacher/HuatuoGPT-o1-7B-GGUF:Q3_K_M  ~3.9 GB（极省内存）
#   hf.co/mradermacher/HuatuoGPT-o1-7B-GGUF:Q4_K_M  ~4.8 GB（默认推荐）⭐
#   hf.co/mradermacher/HuatuoGPT-o1-7B-GGUF:Q5_K_M  ~5.5 GB（质量更好）
#   hf.co/mradermacher/HuatuoGPT-o1-7B-GGUF:Q8_0    ~8.2 GB（接近无损）
# 也可用其它模型：qwen2.5:7b、llama3.1:8b 等
# OLLAMA_MODEL_NAME=hf.co/mradermacher/HuatuoGPT-o1-7B-GGUF:Q4_K_M

# Ollama API 地址（Docker Compose 内自动使用 http://ollama:11434/api/generate）
# OLLAMA_API_URL=http://localhost:11434/api/generate

# ── 2B. OpenAI 兼容配置（LLM_PROVIDER=openai 时生效）──
# 适用：机房 GPU 跑 vLLM / TGI / SGLang，或云端 DeepSeek / 智谱 / Qwen
# OPENAI_API_BASE=http://gpu-host:8000/v1
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
# OPENAI_API_KEY=                          # 自建服务可留空，云端 API 必填
OPENAI_API_BASE=
OPENAI_MODEL=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# 3. 服务配置
# ─────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000
WORKERS=1
MAX_UPLOAD_SIZE_MB=15

# 开发模式热重载（生产环境禁止开启）
RELOAD=0

# LLM 请求超时（秒），生成长任务卡建议 >= 180
# LLM_TIMEOUT_SECONDS=180

# ─────────────────────────────────────────────────────────────
# 4. Embedding 模型 / RAG 配置
# ─────────────────────────────────────────────────────────────

# Embedding 模型名称（默认 BAAI/bge-small-zh-v1.5，轻量中文向量模型）
# EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# 可选：指向本地已下载的模型目录（离线部署必填）
# 例如：/models/bge-small-zh-v1.5
# EMBEDDING_MODEL_LOCAL_PATH=

# Embedding 计算设备：cpu / cuda
# EMBEDDING_DEVICE=cpu

# 是否允许 embedding 加载失败时降级启动
# true = RAG 不可用，但基础 LLM 对话仍正常（推荐演示/比赛环境）
# false = embedding 失败直接退出（推荐生产环境）
EMBEDDING_ALLOW_DEGRADED=true

# ─────────────────────────────────────────────────────────────
# 5. 缓存 / Telemetry 配置（容器内自动设置，本地开发可覆盖）
# ─────────────────────────────────────────────────────────────

# HuggingFace 模型缓存目录（Docker 内默认 /app/.cache/huggingface）
# HF_HOME=/tmp/huggingface
# SENTENCE_TRANSFORMERS_HOME=/tmp/sentence_transformers

# 国内镜像加速 HuggingFace 模型下载
# HF_ENDPOINT=https://hf-mirror.com

# 关闭 ChromaDB 遥测（消除日志噪音）
ANONYMIZED_TELEMETRY=False

# ─────────────────────────────────────────────────────────────
# 6. 部署后操作参考
# ─────────────────────────────────────────────────────────────
#
# 查看当前身份：
#   curl http://localhost:8000/api/auth/me -H "X-Auth-Token: $AUTH_TOKEN"
#
# 创建护工账号：
#   curl -X POST http://localhost:8000/api/auth/users \
#     -H "X-Auth-Token: $AUTH_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"username":"wang_nurse","display_name":"王护士","role":"nurse"}'
#
# 为护工签发 Token（仅返回一次，立即保存）：
#   curl -X POST http://localhost:8000/api/auth/tokens \
#     -H "X-Auth-Token: $AUTH_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"user_id":"usr_xxxxx","label":"护工端平板"}'
#
# 查看审计日志（admin 专属）：
#   curl http://localhost:8000/api/ehr/audit?limit=50 -H "X-Auth-Token: $AUTH_TOKEN"
