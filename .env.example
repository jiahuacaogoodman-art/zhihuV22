# ============================================================
# 智护银伴 · 本地环境变量示例
# 复制为 .env 并按实际情况修改，.env 已被 .gitignore 排除，不会提交到仓库。
# ============================================================

# --- 鉴权 ---
# Phase 1 起，鉴权基于"用户 + 多 API Key"（存于 local_auth/users.db）。
#
# AUTH_TOKEN 现在是 bootstrap token：
#   - 首次启动、UserStore 为空时，会自动创建 username=admin 用户，
#     并把本 token 绑定为其 API Key。
#   - 之后即使删除本变量，admin 的 token 也已入库，继续有效。
#   - 若 UserStore 已有用户，本变量会被忽略。
#
# 留空 + UserStore 为空 → 鉴权关闭（disabled 模式，仅限开发/测试）。
# 生产：使用 openssl rand -hex 32 生成随机 token。
AUTH_TOKEN=

# --- PII 字段加密 ---
# Fernet URL-safe base64 密钥（44 字符）。留空 → 加密关闭（仅限开发/测试）。
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=

# --- 服务监听 ---
HOST=0.0.0.0
PORT=8000

# --- 开发模式热重载（生产禁止开启）---
RELOAD=0

# --- 病历上传限制 ---
MAX_UPLOAD_SIZE_MB=15

# ============================================================
# 新鉴权流程（Phase 1 起）
# ============================================================
#
# 1. 首次部署（或从旧版升级）：
#      export AUTH_TOKEN=$(openssl rand -hex 32)
#      启动服务后，存在一个 admin 用户，token = $AUTH_TOKEN
#
# 2. 新增一个护工账号：
#      curl -X POST http://host/api/auth/users \
#        -H "X-Auth-Token: $AUTH_TOKEN" \
#        -H "Content-Type: application/json" \
#        -d '{"username":"wang_nurse","display_name":"王护士","role":"nurse"}'
#
# 3. 为该账号签发 API Key（token 字段仅此次返回一次，请立即保存）：
#      curl -X POST http://host/api/auth/tokens \
#        -H "X-Auth-Token: $AUTH_TOKEN" \
#        -H "Content-Type: application/json" \
#        -d '{"user_id":"usr_xxxxx","label":"小程序端"}'
#
# 4. 该护工用自己的 token 访问业务接口，审计日志里 operator 会是 "wang_nurse"。
#
# 5. 查看审计日志（admin 专属）：
#      curl http://host/api/ehr/audit?limit=50 -H "X-Auth-Token: $AUTH_TOKEN"
#
# 6. 查看当前登录身份 + 鉴权模式：
#      curl http://host/api/auth/me -H "X-Auth-Token: $TOKEN"
